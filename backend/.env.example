# ==========================================
# FanPass Backend — Environment Configuration
# ==========================================

# ── DATABASE ──────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, or Local)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/fanpass

# ── AUTHENTICATION & SECURITY ──────────────────────────────────
# Secret used by NextAuth to encrypt session cookies (min 32 chars)
NEXTAUTH_SECRET=your-nextauth-secret-here-min-32-chars

# Secret used to sign JWT tokens inside Ticket QR codes
# DO NOT CHANGE THIS AFTER GOING LIVE, or existing tickets will fail validation.
TICKET_JWT_SECRET=your-ticket-signing-secret-here-min-32-chars

# ── APP URLS ──────────────────────────────────────────────────
# Port the backend server listens on
PORT=3001

# The URL of your frontend application (used for CORS and redirect links)
# For multiple origins, use comma-separated values: http://localhost:3000,https://fanpass.app
FRONTEND_URL=http://localhost:3000

# ── CLOUDINARY (MEDIA STORAGE) ────────────────────────────────
# Used for storing receipt screenshots and profile photos
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── GOOGLE GEMINI AI (RECEIPT EXTRACTION) ─────────────────────
# API key for Gemini 1.5 Flash to extract transaction data from receipts
GEMINI_API_KEY=your-gemini-api-key

# Enable/Disable AI extraction (set to false to skip AI processing)
AI_RECEIPT_EXTRACTION=true

# ── BUSINESS LOGIC SETTINGS ──────────────────────────────────
# Enable SMS notifications for organizers (Phase 9)
ORGANIZER_NOTIFICATION_SMS=false

# Limit number of tickets a single person can buy per event
MAX_TICKETS_PER_PERSON=4

# Maximum age of a receipt (in hours) to be considered valid for verification
RECEIPT_MAX_AGE_HOURS=24
