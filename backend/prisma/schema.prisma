// FanPass — Prisma Schema
// Football Influencer Watch Party Platform
// Smart Receipt Verification System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// IMPORTANT: @@map("Organizer") keeps the underlying DB table
// name unchanged. Only the Prisma model name changes to Influencer.
// This is a SAFE migration — no data loss on the live database.
// ============================================================
model Influencer {
  id               String      @id @default(cuid())
  email            String      @unique
  password         String
  phone            String      @unique
  name             String
  slug             String?     @unique // used in /influencers/[slug]
  bio              String?
  profilePhoto     String?     // Cloudinary URL
  teamSupported    String?     // e.g. "Arsenal", "Man United"
  teamColor        String?     // hex color e.g. "#EF0107" for Arsenal
  tiktokUrl        String?
  instagramUrl     String?
  telegramUrl      String?
  isVerified       Boolean     @default(false)
  isActive         Boolean     @default(true)
  totalTicketsSold Int         @default(0)
  createdAt        DateTime    @default(now())
  events           Event[]
  staff            Staff[]
  fanFollows       FanFollow[]

  @@map("Organizer") // safe: keeps existing DB table name
}

model SuperAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  phone     String   @unique
  name      String
  createdAt DateTime @default(now())
}

model Staff {
  id           String       @id @default(cuid())
  email        String       @unique
  password     String
  phone        String
  name         String
  influencer   Influencer   @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  organizerId  String
  assignments  EventStaff[]
  scanLogs     ScanLog[]
  createdAt    DateTime     @default(now())

  @@map("Staff")
}

model Event {
  id               String       @id @default(cuid())
  influencer       Influencer   @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  organizerId      String
  title            String
  description      String?
  venue            String
  venueMapUrl      String?
  dateTime         DateTime
  ticketPrice      Int          // stored in smallest currency unit (santim)
  currency         String       @default("ETB")
  maxCapacity      Int
  ticketsSold      Int          @default(0)
  status           EventStatus  @default(DRAFT)
  refundPolicy     String?      // instructions for manual refunds
  organizerContact String?      // contact for refund queries
  refundStatus     String?      // e.g. "NOT_STARTED", "IN_PROGRESS", "COMPLETED"
  slug             String       @unique // used in public URL: /events/[slug]
  createdAt        DateTime     @default(now())

  // Match-specific fields
  homeTeam         String?      // e.g. "Arsenal"
  awayTeam         String?      // e.g. "Man City"
  competition      String?      // e.g. "Premier League", "Champions League"
  matchKickoff     DateTime?    // actual match kick-off time
  coverImage       String?      // Cloudinary URL for event cover
  city             String?      // city for filtering, e.g. "Addis Ababa"

  // Payment instruction fields (shown to fan after clicking Buy)
  paymentInstructions String?   // free text e.g. "Send to Telebirr: 0911 XXX XXX"
  paymentAccounts     Json?     // structured: [{ type: "Telebirr", number: "0911...", name: "Dawit H." }, ...]
  expectedAmount      Int?      // ticket price in ETB — used by AI to validate extracted amount

  tickets          Ticket[]
  staffAssignments EventStaff[]
  scanLogs         ScanLog[]
}

enum EventStatus {
  DRAFT
  ACTIVE
  SALES_CLOSED
  LIVE
  COMPLETED
  CANCELLED
}

model Ticket {
  id          String       @id @default(cuid())
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId     String
  buyerPhone  String
  buyerName   String?
  qrToken     String?      @unique // signed JWT — nullable until approval confirmed
  status      TicketStatus @default(PENDING)
  issuedAt    DateTime     @default(now())
  scannedAt   DateTime?
  ticketCount Int          @default(1) // number of tickets in this submission
  note        String?      // optional note from fan

  // Receipt verification fields
  screenshotUrl        String?        // uploaded receipt image URL (Cloudinary)
  screenshotUploadedAt DateTime?
  imageHash            String?        // perceptual hash for duplicate detection

  // AI-extracted data from the receipt
  extractedAmount      Float?         // amount read by AI from screenshot
  extractedSenderName  String?        // name/account AI detected as sender
  extractedDate        String?        // date string extracted from receipt
  extractedRef         String?        // transaction reference number if visible
  aiConfidenceScore    Float?         // 0.0 to 1.0 — how confident the AI is
  aiRawText            String?        // full raw text extracted, stored for audit

  // Admin decision
  verificationStatus   VerificationStatus @default(PENDING_EXTRACTION)
  reviewedBy           String?        // admin/organizer user ID who approved/rejected
  reviewedAt           DateTime?
  rejectionReason      String?        // filled if rejected, shown to fan

  // SMS Notification tracking
  smsStatus            SmsStatus?
  smsRetryCount        Int            @default(0)
  lastSmsAttempt       DateTime?
  smsError             String?

  scanLogs    ScanLog[]
}

enum SmsStatus {
  PENDING
  SENT
  FAILED
}

enum TicketStatus {
  PENDING
  ISSUED
  SCANNED
  EXPIRED
  CANCELLED_PENDING_REFUND
  REFUND_CONFIRMED
}

enum VerificationStatus {
  PENDING_EXTRACTION
  EXTRACTED_HIGH_CONFIDENCE
  EXTRACTED_LOW_CONFIDENCE
  MANUAL_REVIEW_REQUIRED
  VERIFIED
  REJECTED
}


model EventStaff {
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId String

  @@id([eventId, staffId])
}

model ScanLog {
  id            String     @id @default(cuid())
  ticket        Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId      String
  event         Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId       String
  staff         Staff?     @relation(fields: [staffId], references: [id])
  staffId       String?
  scannedById   String     // Can be staffId or organizerId
  scannedByRole String     // "STAFF" | "ORGANIZER" | "SUPER_ADMIN"
  result        String     // "VALID" | "ALREADY_USED" | "INVALID" | "WRONG_EVENT"
  scannedAt     DateTime   @default(now())
  deviceInfo    String?

  @@index([eventId, scannedAt])
}

// OtpCode model removed


// Phase 2: Fan follow / favourites (optional)
model FanFollow {
  id           String     @id @default(cuid())
  fanPhone     String
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  influencerId String
  createdAt    DateTime   @default(now())

  @@unique([fanPhone, influencerId])
}
