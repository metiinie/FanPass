# ===========================
# FanPass Environment Variables
# ===========================

# Database (PostgreSQL — Neon, Supabase, Railway, or local)
DATABASE_URL=postgresql://user:password@host:5432/fanpass?sslmode=require

# NextAuth.js v5
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-minimum-32-chars-here

# Ticket QR JWT Signing Secret (min 32 characters)
TICKET_JWT_SECRET=your-ticket-signing-secret-minimum-32-chars

# Telebirr Payment (Phase 8 — leave blank for simulation mode)
TELEBIRR_APP_ID=
TELEBIRR_APP_KEY=
TELEBIRR_SECRET=
TELEBIRR_SHORT_CODE=
TELEBIRR_BASE_URL=https://api.telebirr.com

# Africa's Talking SMS (Phase 9 — leave blank for simulation mode)
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=FanPass

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
