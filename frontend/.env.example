# ==========================================
# FanPass Frontend — Environment Configuration
# ==========================================

# ── API CONNECTION ───────────────────────────────────────────
# The public URL of your NestJS backend
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# The public URL of this frontend application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── NEXTAUTH.JS CONFIG ───────────────────────────────────────
# The canonical URL of your site (required for production)
NEXTAUTH_URL=http://localhost:3000

# Secret used to encrypt session cookies (Must match backend NEXTAUTH_SECRET)
# You can generate one using: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here-min-32-chars

# Trust host (required for some deployment environments like Vercel)
AUTH_TRUST_HOST=true

# ── TICKETING SECURITY ───────────────────────────────────────
# Secret used to sign/verify QR code JWTs (Must match backend TICKET_JWT_SECRET)
TICKET_JWT_SECRET=your-ticket-signing-secret-here

# ── SMS PROVIDER (AFRICA'S TALKING) ──────────────────────────
# Leave blank to use simulation mode in development
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=FanPass

# ── ANALYTICS & MONITORING (OPTIONAL) ────────────────────────
# Add any production analytics keys here
